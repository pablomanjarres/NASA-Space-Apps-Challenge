# OpenAI API Configuration for AI Chatbot
# This key should be set in Vercel environment variables for production
# For local development, copy this file to .env and add your key
OPENAI_API_KEY=your_openai_api_key_here

# Backend API URL (optional)
VITE_API_URL=http://localhost:8000

# Key-free DEMO mode
# ON by default (the deployed site runs with no backend and no API keys):
# predictions return canned sample data, dataset browsing falls back to a
# bundled sample if Supabase is unreachable, and the AI chatbot returns a
# graceful canned reply. Set PUBLIC_DEMO=false to use the live backend + keys.
# PUBLIC_DEMO=false
